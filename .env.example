# Copy this file to .env and fill in values before running docker-compose.
# Never commit .env to version control.

# Grafana admin credentials (defaults to admin/admin for local dev)
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# MLflow configuration for experiment tracking and model registry
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_MODEL_NAME=credit_score_serving
MLFLOW_MODEL_ALIAS=production
MLFLOW_EXPERIMENT_NAME=credit-score-v1