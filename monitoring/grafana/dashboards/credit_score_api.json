{
  "title": "Credit Score API",
  "uid": "credit-score-api",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Predictions",
      "gridPos": {"x": 0, "y": 0, "w": 4, "h": 4},
      "targets": [{
        "expr": "sum(credit_score_requests_total{status=\"ok\"})",
        "legendFormat": "Total"
      }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error Rate",
      "gridPos": {"x": 4, "y": 0, "w": 4, "h": 4},
      "targets": [{
        "expr": "sum(rate(credit_score_requests_total{status=\"error\"}[5m])) / sum(rate(credit_score_requests_total[5m]))",
        "legendFormat": "Error Rate"
      }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Model Loaded",
      "gridPos": {"x": 8, "y": 0, "w": 4, "h": 4},
      "targets": [{
        "expr": "credit_score_model_loaded",
        "legendFormat": "Loaded"
      }]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Request Rate (req/s)",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 7},
      "targets": [
        {
          "expr": "sum(rate(credit_score_requests_total{status=\"ok\"}[1m])) by (endpoint)",
          "legendFormat": "{{endpoint}} ok"
        },
        {
          "expr": "sum(rate(credit_score_requests_total{status=\"error\"}[1m])) by (endpoint)",
          "legendFormat": "{{endpoint}} error"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Latency Percentiles (ms)",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 7},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(credit_score_request_latency_ms_bucket[5m])) by (le, endpoint))",
          "legendFormat": "p50 {{endpoint}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(credit_score_request_latency_ms_bucket[5m])) by (le, endpoint))",
          "legendFormat": "p95 {{endpoint}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(credit_score_request_latency_ms_bucket[5m])) by (le, endpoint))",
          "legendFormat": "p99 {{endpoint}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "piechart",
      "title": "Predictions by Class",
      "gridPos": {"x": 0, "y": 11, "w": 8, "h": 7},
      "targets": [{
        "expr": "sum(credit_score_predictions_by_class_total) by (predicted_class)",
        "legendFormat": "{{predicted_class}}"
      }]
    }
  ]
}
