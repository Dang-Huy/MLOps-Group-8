{
  "title": "Credit Score API",
  "uid": "credit-score-api",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Model Loaded",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "value": 0, "color": "red" }, { "value": 1, "color": "green" }] }
        }
      },
      "targets": [{ "expr": "credit_score_model_loaded", "legendFormat": "" }]
    },
    {
      "id": 2,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 4, "y": 0, "w": 10, "h": 8 },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } },
      "targets": [
        { "expr": "rate(credit_score_requests_total{status=\"success\"}[1m])", "legendFormat": "Success" },
        { "expr": "rate(credit_score_requests_total{status=\"error\"}[1m])", "legendFormat": "Error" }
      ]
    },
    {
      "id": 3,
      "title": "P95 Latency (ms)",
      "type": "timeseries",
      "gridPos": { "x": 14, "y": 0, "w": 10, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(credit_score_request_latency_ms_bucket[1m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(credit_score_request_latency_ms_bucket[1m]))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, rate(credit_score_request_latency_ms_bucket[1m]))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 4,
      "title": "Total Requests",
      "type": "stat",
      "gridPos": { "x": 0, "y": 4, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(credit_score_requests_total)", "legendFormat": "" }]
    },
    {
      "id": 5,
      "title": "Prediction Distribution",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 8 },
      "targets": [
        { "expr": "credit_score_predictions_by_class_total{credit_class=\"Poor\"}", "legendFormat": "Poor" },
        { "expr": "credit_score_predictions_by_class_total{credit_class=\"Standard\"}", "legendFormat": "Standard" },
        { "expr": "credit_score_predictions_by_class_total{credit_class=\"Good\"}", "legendFormat": "Good" }
      ]
    },
    {
      "id": 6,
      "title": "Prediction Rate by Class",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 8, "w": 16, "h": 8 },
      "targets": [
        { "expr": "rate(credit_score_predictions_by_class_total[1m])", "legendFormat": "{{credit_class}}" }
      ]
    },
    {
      "id": 7,
      "title": "Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100 } },
      "targets": [
        { "expr": "100 * rate(credit_score_requests_total{status=\"error\"}[1m]) / clamp_min(rate(credit_score_requests_total[1m]), 0.001)", "legendFormat": "Error Rate" }
      ]
    },
    {
      "id": 8,
      "title": "Latency Heatmap",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "targets": [
        { "expr": "rate(credit_score_request_latency_ms_sum[1m]) / rate(credit_score_request_latency_ms_count[1m])", "legendFormat": "avg latency" }
      ]
    }
  ]
}
